# =============================================================================
# .gitignore — RAG Pipeline (Truth Engine)
# =============================================================================


# -----------------------------------------------------------------------------
# Environment & Secrets — NEVER commit these
# -----------------------------------------------------------------------------
.env
.env.*
*.env
.envrc

# API keys if stored in a config file
config/secrets.py
secrets.py
api_keys.py


# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/
wheels/
pip-wheel-metadata/
MANIFEST

# Type checking
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/
.pyre/

# Unit test / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
nosetests.xml
test-results.xml


# -----------------------------------------------------------------------------
# Virtual environments
# -----------------------------------------------------------------------------
.venv/
venv/
env/
ENV/
.virtualenv/


# -----------------------------------------------------------------------------
# RAG Pipeline — generated data (too large / sensitive for git)
# -----------------------------------------------------------------------------

# ChromaDB persisted vector index
chroma_db/

# BM25 corpus
bm25_store/

# Ingestion outputs / cached chunks
*.chunks.json

# Test results generated by run_evaluation.py
tests/test_results.json


# -----------------------------------------------------------------------------
# ML Models — downloaded at runtime, not committed
# -----------------------------------------------------------------------------

# SentenceTransformer + CrossEncoder model cache
# (downloaded automatically by HuggingFace to these locations)
.cache/
models/
*.bin
*.safetensors
*.onnx
*.pt
*.pth


# -----------------------------------------------------------------------------
# Jupyter Notebooks — checkpoints only, keep .ipynb if you use them
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
*/.ipynb_checkpoints/


# -----------------------------------------------------------------------------
# OS generated files
# -----------------------------------------------------------------------------

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encdata
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~


# -----------------------------------------------------------------------------
# IDEs & editors
# -----------------------------------------------------------------------------

# VSCode
.vscode/
*.code-workspace

# PyCharm / JetBrains
.idea/
*.iml
*.iws
*.ipr

# Vim / Emacs
*.swp
*.swo
*.swn
.#*
\#*#


# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/
*.log.*


